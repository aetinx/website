---
import { ClientRouter } from "astro:transitions"
import "../styles/global.css"
import ReplacementSwap from "../components/ReplacementSwap.astro"
import Section from "../components/Section.astro"
import Navbar from "../components/Navbar.jsx"
import Meta from "../components/Meta.astro"
import SoundHandler from "../components/SoundHandler"
---

<!doctype html>
<html lang="en">
  <head>
    <Meta metadata={Astro.props.metadata || {}} />
    <ClientRouter />
    <ReplacementSwap />
  </head>
  <body class="font-sans font-medium text-pretty" transition:animate="none">
    <ReplacementSwap />
    <SoundHandler client:load transition:persist />
    <Section>
      <Navbar client:load transition:persist />
    </Section>
    <script is:inline>
      document.addEventListener("astro:before-swap", e => {
        if (e.from.href === e.to.href) {
          e.swap = () => {}
        }
      })
    </script>
    <div transition:animate="fade" data-vtbot-replace>
      <slot />
    </div>
  </body>
</html>
