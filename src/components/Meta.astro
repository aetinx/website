---
export const partial = true

const { metadata = {}, ogdata = {} } = Astro.props

const title = metadata.title ? `${metadata.title}\u2002\u2013\u2002Adrian Keim` : "Adrian Keim"
const description =
  metadata.description ??
  "Adrian Keim (@aetinx) is a product designer and engineer who designs brands, products, interfaces, lettering, and video game liveries."

const og = {
  title: ogdata.title || title,
  description: ogdata.description ?? metadata.description ?? "Portfolio and personal site of designer Adrian Keim (@aetinx).",
  image: new URL("og.png", Astro.site),
  url: new URL(Astro.url.pathname, Astro.site)
}

const wwwschema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Adrian Keim",
  alternateName: "Aetinx",
  url: og.url
}

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  mainEntity: {
    "@type": "Person",
    name: "Adrian Keim",
    alternateName: "Aetinx",
    identifier: "aetinx",
    description,
    image: "https://github.com/aetinx.png",
    sameAs: ["https://x.com/aetinx", "https://github.com/aetinx", "https://linkedin.com/in/aetinx"],
  }
}

import instrumentSansTTF from "../assets/fonts/InstrumentSans-VariableFont_wdth,wght.ttf?url"
---

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={og.url} />
<meta property="og:title" content={og.title} />
<meta property="og:description" content={og.description} />
<meta property="og:image" content={og.image} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={og.url} />
<meta property="twitter:title" content={og.title} />
<meta property="twitter:description" content={og.description} />
<meta property="twitter:image" content={og.image} />
<meta property="twitter:site" content="aetinx" />

<meta name="theme-color" content="#ff00aa" />

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

<link rel="sitemap" href="/sitemap-index.xml" />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
<link rel="icon" type="image/png" href="/favicon.png" sizes="any" />

<link rel="preload" href={instrumentSansTTF} as="font" type="font/ttf" crossorigin />

<link rel="me" href="https://x.com/aetinx" />
<link rel="me" href="https://github.com/aetinx" />
<link rel="me" href="https://www.linkedin.com/in/aetinx/" />

<script type="application/ld+json" set:html={JSON.stringify(wwwschema, null, 2)} is:inline />
<script type="application/ld+json" set:html={JSON.stringify(schema, null, 2)} is:inline />
